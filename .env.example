# Anthropic — get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=${{secrets.ANTHROPIC_API_KEY}}

# Notion integration token — get from https://www.notion.so/my-integrations
NOTION_TOKEN= ${{secret.NOTION_TOKEN}}

# The Notion page that will contain the bug-tracker database.
# Create a blank page in Notion, share it with your integration, then paste its ID here.
# Format: the long hex string at the end of the page URL
NOTION_PARENT_PAGE_ID=

# Auto-populated on first run — leave blank to let the agent create the database
NOTION_DATABASE_ID=

# Webhook server port (default: 3000)
PORT=3000
